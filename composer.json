{
    "name": "autowash-pro/application",
    "description": "Nền tảng Modern PHP cho AutoWash Pro",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-fileinfo": "*",
        "ext-pdo": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "db:migrate": "php database/migrate.php",
        "db:seed": "php database/seed.php --demo",
        "db:seed-defense": "php database/seed-defense.php",
        "release:audit": "php scripts/release-audit.php",
        "check": [
            "@lint",
            "@test",
            "@release:audit"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
